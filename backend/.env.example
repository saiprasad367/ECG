# FastAPI
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ecg_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecg-analysis
MINIO_SECURE=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Session
SESSION_TTL_HOURS=24

# Security
ENCRYPTION_KEY=your-fernet-key-here-generate-with-python
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Model
MODEL_PATH=models/best_model.pth
QUANTIZED_MODEL_PATH=models/quantized_model.pth

# Rate limiting
RATE_LIMIT_UPLOADS=10/hour
RATE_LIMIT_INFERENCE=20/hour
